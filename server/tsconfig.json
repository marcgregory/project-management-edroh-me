{
  "compilerOptions": {
    "target": "es2023",
    "module": "commonjs", // Use CommonJS for Node
    "rootDir": "./src", // Source files folder
    "outDir": "./dist", // Compiled output folder
    "esModuleInterop": true, // Needed for default imports
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true, // Optional: generate .d.ts
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "next-env.d.ts"],
  "exclude": ["node_modules", "dist"]
}
